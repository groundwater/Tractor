#!/bin/bash
set -e
mkdir -p /usr/local/bin
# Install a thin wrapper rather than a symlink: NETransparentProxyManager
# uses Bundle.main to locate the embedded sysext, and a symlinked entry
# point makes Bundle.main resolve to /usr/local/bin instead of the .app,
# breaking NE provider lookup. The exec form lets the .app become the
# launch context so Bundle.main = .../Tractor.app.
# If a prior install left /usr/local/bin/tractor as a symlink, `cat >` would
# follow it and clobber the target (the .app's Mach-O binary). Always remove
# any existing entry before writing the wrapper.
rm -f /usr/local/bin/tractor
cat > /usr/local/bin/tractor <<'EOF'
#!/bin/sh
exec "/Library/Application Support/Tractor/Tractor.app/Contents/MacOS/Tractor" "$@"
EOF
chmod 755 /usr/local/bin/tractor
exit 0
