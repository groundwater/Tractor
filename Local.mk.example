# Copy to Local.mk and fill in. Local.mk is gitignored.
# Used by the release targets: `make dmg`, `make notarize-dmg`, `make dist`.

# notarytool keychain profile. Create it once with:
#   xcrun notarytool store-credentials AC_PASSWORD \
#     --apple-id you@example.com \
#     --team-id TEAMID \
#     --password <app-specific-password>
NOTARYTOOL_KEYCHAIN_PROFILE = AC_PASSWORD
